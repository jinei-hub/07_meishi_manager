# ─────────────────────────────────────────
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# ─────────────────────────────────────────

# ── Claude API (名刺の読み取りに使用) ──────
# https://console.anthropic.com で API キーを取得
# 02_sns_analyser/.env に既にキーがあれば同じ値を流用可
ANTHROPIC_API_KEY=
# 使用モデル（未指定なら claude-opus-4-8）
ANTHROPIC_MODEL=claude-opus-4-8

# ── アプリ設定 ──────────────────────────
# SQLite DB ファイルパス
DATABASE_URL=sqlite:///data/meishi.db
