# Streamlit Community Cloud の「Secrets」に貼り付ける内容のテンプレート。
# 実際の secrets.toml はコミットしないこと（.gitignore 済み）。
# クラウドのアプリ設定画面 → Settings → Secrets に、下の3行を値入りで貼る。

ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx"
ANTHROPIC_MODEL = "claude-opus-4-8"
# Neon のダッシュボードでコピーした接続文字列（?sslmode=require まで含める）
DATABASE_URL = "postgresql://user:password@ep-xxxx.aws.neon.tech/neondb?sslmode=require"
